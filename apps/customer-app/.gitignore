# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Dependencies
node_modules/
yarn.lock  # Ignore if using npm; prevents conflicts

# Builds and distributions
.expo/
dist/
web-build/
build/
*.apk
*.ap_
*.dex
*.class
*.ipa
*.jsbundle

# Expo-specific
expo-env.d.ts
.metro-health-check*

# Native Android
android/.gradle/
android/app/build/
android/build/
android/local.properties
*.iml
*.keystore
!debug.keystore
.kotlin/

# Native iOS
ios/build/
ios/DerivedData/
ios/*.xcworkspace/xcuserdata/
ios/Pods/  # Add if using CocoaPods; remove if not
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*.xccheckout
*.moved-aside
*.hmap
*.xcuserstate

# Environment and secrets
.env
.env*.local
*.pem
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Logs and debug
npm-debug.*
yarn-debug.*
yarn-error.*
*.log
debug.log

# OS-specific (macOS)
.DS_Store
.Apple*
Thumbs.db
ehthumbs.db

# Editor and temp files
.vscode/*
!*.vscode/settings.json  # Commit shared VS Code settings if needed
*.orig.*
*.bak
*.swp
*~
.tmp
.temp
.history/
.tsbuildinfo

# Misc/custom
app-example